# Opcional: aponta a execução local para o projeto Supabase hospedado em vez do stack local
# (`supabase start`). Sem este arquivo, os testes e o scraper usam o stack local por padrão.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Plataforma do job. O default "all" preserva a execução local completa; o GitHub Actions
# sempre seleciona uma plataforma, para isolar falhas e evitar dois tiers no mesmo run.
SCRAPE_PLATFORM=all

# Tier das plataformas com coleta tiered. O default é "active"; use "tail" no disparo
# diário da cauda (Cuponomia ~55 lojas, Méliuz ~337 lojas).
SCRAPE_TIER=active
