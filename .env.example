# Opcional: aponta a execução local para o projeto Supabase hospedado em vez do stack local
# (`supabase start`). Sem este arquivo, os testes e o scraper usam o stack local por padrão.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# URL Supavisor em transaction mode, exclusiva do Server Components da Vercel.
# Nunca use prefixo NEXT_PUBLIC_ nem credenciais service_role nesta variável.
FAREJO_WEB_DATABASE_URL=

# URL Supavisor da role farejo_curation (login), exclusiva de `pnpm --filter @farejo/scraper
# run curate:apply` (F3/T12). Nunca service_role; nunca enviada à Vercel.
FAREJO_CURATION_DATABASE_URL=

# Origem pública canônica usada em canonical, robots e sitemap.
FAREJO_SITE_URL=https://farejo.com.br

# Plataforma do job. O default "all" preserva a execução local completa; o GitHub Actions
# sempre seleciona uma plataforma, para isolar falhas e evitar dois tiers no mesmo run.
SCRAPE_PLATFORM=all

# Tier das plataformas com coleta tiered. O default é "active"; use "tail" no disparo
# diário da cauda (Cuponomia ~55 lojas, Méliuz ~337 lojas).
SCRAPE_TIER=active
